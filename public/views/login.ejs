<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Task Manager - Login</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <script src="https://kit.fontawesome.com/98e2b2ba81.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="css/login.css">
</head>

<body>
    <div class="container">
        <!-- login  -->
        <div class="glass-card login" id="loginBox">
            <div class="card-left flex">
                <div class="info-content">
                    <div class="circle flex">
                        <i class="fa-solid fa-user-shield"></i>
                    </div>
                    <h2>Welcome Back!</h2>
                    <p>Log in to access your secure notes and keep your thoughts synced across all your devices.</p>
                </div>
            </div>

            <div class="card-right flex">
                <h3 class="mobile-title">Welcome Back!</h3>
                <div class="loginMessage message"></div>

                <div class="form-group">
                    <label for="accNum">Email ID</label>
                    <div class="inpBox flex" id="loginMail">
                        <i class="fa-solid fa-envelope"></i>
                        <input id="accNum" class="inputTag" placeholder="Enter your email" type="email">
                    </div>
                </div>

                <div class="form-group">
                    <label for="signInPinNum">Password</label>
                    <div class="inpBox flex" id="loginPass">
                        <i class="fas fa-lock input-icon"></i>
                        <input id="signInPinNum" class="inputTag" placeholder="Enter your password" type="password">
                    </div>
                </div>

                <button class="btn flex hover-trigger" id="signInBtn">
                    <span>Sign In</span> <i class="fa-solid fa-right-to-bracket transition-icon"></i>
                </button>

                <div class="switch-text">
                    Don't have an account? <span id="createAccBtn" class="highlight-link">Create one</span>
                </div>
            </div>
        </div>

        <!-- Sign Up -->
        <div class="glass-card signUp" id="signUpBox">
            <div class="card-left flex">
                <div class="info-content">
                    <div class="circle flex">
                        <i class="fas fa-user-plus" style="margin-left: 5px;"></i>
                    </div>
                    <h2>Create Account</h2>
                    <p>Explore Our Task Manager and be calm about all your daily tasks.</p>
                </div>
            </div>

            <div class="card-right flex">
                <h3 class="mobile-title">Create Account</h3>
                <p class="signUpMessage message">
                    Account created successfully!
                </p>

                <div class="form-group">
                    <label for="accName">Full Name</label>
                    <div class="inpBox flex" id="nameBox">
                        <i class="fa-solid fa-user"></i>
                        <input id="accName" class="inputTag" placeholder="Enter your full name" type="text">
                    </div>
                </div>

                <div class="form-group">
                    <label for="email">Email ID</label>
                    <div class="inpBox flex" id="emailBox">
                        <i class="fa-solid fa-envelope"></i>
                        <input id="email" class="inputTag" placeholder="Enter your email ID" type="email">
                    </div>
                </div>

                <div class="form-group">
                    <label for="signUpPinNum">Password</label>
                    <div class="inpBox flex" id="passwordBox">
                        <i class="fas fa-lock input-icon"></i>
                        <input id="signUpPinNum" class="inputTag" placeholder="Create a password" type="password">
                    </div>
                </div>

                <button class="btn flex hover-trigger" id="signUpSubmit">
                    <span>Sign Up</span> <i class="fa-solid fa-user-check transition-icon"></i>
                </button>

                <div class="switch-text">
                    Already have an account? <span id="backToLoginBtn" class="highlight-link">Back to Login</span>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="javaScript/signUp.js"></script>
</body>

</html>